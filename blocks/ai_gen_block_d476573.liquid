{% doc %}
  @prompt
    need a short header and descripton section , with a place to add logo. make it flexible to edit, logo isnt working, it doesnt show
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-header-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
background-color: #0f3c39;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-header-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-header-logo-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.logo_spacing }}px;
  }

  .ai-header-logo-{{ ai_gen_id }} img {
    max-width: {{ block.settings.logo_width }}px;
    height: auto;
    {% if block.settings.text_alignment == 'center' %}
      margin: 0 auto;
      display: block;
    {% elsif block.settings.text_alignment == 'right' %}
      margin-left: auto;
      display: block;
    {% endif %}
  }

  .ai-header-logo-placeholder-{{ ai_gen_id }} {
    max-width: {{ block.settings.logo_width }}px;
    height: 80px;
    background-color: #f4f4f4;
    border: 2px dashed #ccc;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    {% if block.settings.text_alignment == 'center' %}
      margin: 0 auto;
    {% elsif block.settings.text_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  .ai-header-logo-placeholder-{{ ai_gen_id }} svg {
    width: 40px;
    height: 40px;
    opacity: 0.5;
  }

  .ai-header-title-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font_family.family }}, {{ settings.type_header_font_family.fallback_families }};
    font-weight: {{ settings.type_header_font_family.weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ settings.type_header_line_height }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    {% if settings.type_header_capitalize %}
      text-transform: uppercase;
    {% endif %}
    letter-spacing: {{ settings.type_header_spacing | divided_by: 1000.0 }}em;
  }

  .ai-header-description-{{ ai_gen_id }} {
    font-family: {{ settings.type_base_font_family.family }}, {{ settings.type_base_font_family.fallback_families }};
    font-weight: {{ settings.type_base_font_family.weight }};
    font-size: {{ block.settings.description_size }}px;
    line-height: {{ settings.type_base_line_height }};
    color: {{ block.settings.description_color }};
    margin: 0;
    letter-spacing: {{ settings.type_base_spacing | divided_by: 1000.0 }}em;
  }

  .ai-header-description-{{ ai_gen_id }} p {
    margin: 0 0 1em;
  }

  .ai-header-description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-header-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 0 {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-header-container-{{ ai_gen_id }} {
      padding: 0 15px;
    }

    .ai-header-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-header-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-header-logo-{{ ai_gen_id }} img {
      max-width: {{ block.settings.logo_width | times: 0.8 }}px;
    }

    .ai-header-logo-placeholder-{{ ai_gen_id }} {
      max-width: {{ block.settings.logo_width | times: 0.8 }}px;
      height: 60px;
    }
  }
{% endstyle %}

<div class="ai-header-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-header-container-{{ ai_gen_id }}">
    {% if block.settings.show_logo %}
      <div class="ai-header-logo-{{ ai_gen_id }}">
        {% if block.settings.logo %}
          {% assign logo_width_2x = block.settings.logo_width | times: 2 %}
          <img
            src="{{ block.settings.logo | image_url: width: logo_width_2x }}"
            alt="{{ block.settings.logo.alt | default: shop.name | escape }}"
            width="{{ block.settings.logo_width }}"
            height="{{ block.settings.logo_width | divided_by: block.settings.logo.aspect_ratio | round }}"
            loading="lazy"
          >
        {% else %}
          <div class="ai-header-logo-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-header-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-header-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Header with logo",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show logo",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 150
    },
    {
      "type": "range",
      "id": "logo_spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Logo bottom spacing",
      "default": 20
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Container width",
      "default": 800
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Heading bottom spacing",
      "default": 15
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Header with logo"
    }
  ],
  "tag": null
}
{% endschema %}