{% doc %}
  @prompt
    Create a Shopify section called “Opening Hours” that displays:
    
    A title with a small clock icon on the left.
    
    Two rows showing weekdays and weekend hours, each with a label (e.g., “Sunday – Wednesday”) and corresponding hours (e.g., “5:00 PM – 12:00 AM”).
    
    Two buttons below the hours:
      - Get Directions button
      - Book a Table button
    
    Both buttons should be independently customizable, so I can choose different background colors and hover states for each button in the Shopify editor.
    
    The section should have a card layout with a light background, subtle shadow, rounded corners, and centered content.
    
    Text should be easily editable via the Shopify section settings, including:
      - Section title
      - Weekday label and hours
      - Weekend label and hours
      - Button text and links
    
    The section should be mobile-responsive, adjusting spacing and font sizes on smaller screens., add a line beneath "opening hours" like a divider, and make the two buttons beneath eachother not next to eachother, ok i want both buttons to be longer, align it with the content thats above it, whereve they start n finish. please give it space to breathe when u adjust on mobile. so it doesnt cover the entire screen. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
 
.ai-opening-hours-section-wrapper-{{ ai_gen_id }} {
    background-color: #0F3C39; /* green for the section */
    padding: 60px 0; /* spacing above and below the block */
}

  .ai-opening-hours-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    padding: 40px;
    text-align: center;
    max-width: 500px;
    margin: 0 auto;
  }

  .ai-opening-hours-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .ai-opening-hours-title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0;
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font.style }};
  }

  .ai-opening-hours-clock-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
    flex-shrink: 0;
  }

  .ai-opening-hours-divider-{{ ai_gen_id }} {
    width: 100%;
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    margin: 16px 0 32px 0;
  }

  .ai-opening-hours-schedule-{{ ai_gen_id }} {
    margin-bottom: 32px;
  }

  .ai-opening-hours-row-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    padding: 0 8px;
  }

  .ai-opening-hours-row-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-opening-hours-label-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: 500;
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-style: {{ block.settings.text_font.style }};
  }

  .ai-opening-hours-time-{{ ai_gen_id }} {
    color: {{ block.settings.time_color }};
    font-size: {{ block.settings.text_size }}px;
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-style: {{ block.settings.text_font.style }};
  }

  .ai-opening-hours-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-opening-hours-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 24px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    text-align: center;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    width: 100%;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-style: {{ block.settings.button_font.style }};
  }

  .ai-opening-hours-button-directions-{{ ai_gen_id }} {
    background-color: {{ block.settings.directions_button_color }};
    color: {{ block.settings.directions_button_text_color }};
  }

  .ai-opening-hours-button-directions-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.directions_button_hover_color }};
    color: {{ block.settings.directions_button_hover_text_color }};
  }

  .ai-opening-hours-button-booking-{{ ai_gen_id }} {
    background-color: {{ block.settings.booking_button_color }};
    color: {{ block.settings.booking_button_text_color }};
  }

  .ai-opening-hours-button-booking-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.booking_button_hover_color }};
    color: {{ block.settings.booking_button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-opening-hours-{{ ai_gen_id }} {
      padding: 24px;
      margin: 0 16px;
      border-radius: {{ block.settings.border_radius | times: 0.8 }}px;
    }

    .ai-opening-hours-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-opening-hours-clock-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.9 }}px;
      height: {{ block.settings.icon_size | times: 0.9 }}px;
    }

    .ai-opening-hours-label-{{ ai_gen_id }},
    .ai-opening-hours-time-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-opening-hours-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
      padding: 12px 20px;
    }

    .ai-opening-hours-row-{{ ai_gen_id }} {
      padding: 0 4px;
    }
  }
{% endstyle %}

<div class="ai-opening-hours-section-wrapper-{{ ai_gen_id }}">
<div class="ai-opening-hours-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-opening-hours-header-{{ ai_gen_id }}">
    <svg class="ai-opening-hours-clock-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"></circle>
      <polyline points="12,6 12,12 16,14"></polyline>
    </svg>
    <h2 class="ai-opening-hours-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  </div>

  <div class="ai-opening-hours-divider-{{ ai_gen_id }}"></div>

  <div class="ai-opening-hours-schedule-{{ ai_gen_id }}">
    <div class="ai-opening-hours-row-{{ ai_gen_id }}">
      <span class="ai-opening-hours-label-{{ ai_gen_id }}">{{ block.settings.weekday_label }}</span>
      <span class="ai-opening-hours-time-{{ ai_gen_id }}">{{ block.settings.weekday_hours }}</span>
    </div>
    <div class="ai-opening-hours-row-{{ ai_gen_id }}">
      <span class="ai-opening-hours-label-{{ ai_gen_id }}">{{ block.settings.weekend_label }}</span>
      <span class="ai-opening-hours-time-{{ ai_gen_id }}">{{ block.settings.weekend_hours }}</span>
    </div>
  </div>

  <div class="ai-opening-hours-buttons-{{ ai_gen_id }}">
    {% if block.settings.directions_button_text != blank %}
      <a href="{{ block.settings.directions_button_link }}" class="ai-opening-hours-button-{{ ai_gen_id }} ai-opening-hours-button-directions-{{ ai_gen_id }}">
        {{ block.settings.directions_button_text }}
      </a>
    {% endif %}
    
    {% if block.settings.booking_button_text != blank %}
      <a href="{{ block.settings.booking_button_link }}" class="ai-opening-hours-button-{{ ai_gen_id }} ai-opening-hours-button-booking-{{ ai_gen_id }}">
        {{ block.settings.booking_button_text }}
      </a>
    {% endif %}
  </div>
</div>
</div>

