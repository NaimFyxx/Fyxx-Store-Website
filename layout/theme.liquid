    {%- comment -%}
      ===== FYXX CUSTOM: Apple Smart App Banner =====
      iOS Safari shows a native banner that auto-detects whether the Fyxx app is
      installed: it says "Open" if it is, "Get" if it isn't. This is the only
      reliable way for the web to know the app is installed on iOS, so the custom
      "Download the App" floater further down is now Android-only.
      app-id 1489325138 = "Fyxx: Premium Drinks Delivered" on the App Store.
    {%- endcomment -%}
    <meta name="apple-itunes-app" content="app-id=1489325138">
    {%- comment -%} ===== END FYXX CUSTOM ===== {%- endcomment -%}

    {%- if settings.favicon != blank -%}
      <link rel="shortcut icon" href="{{ settings.favicon | img_url: '32x32' }}" type="image/png">
    {%- endif -%}

    {%- render 'head.page-title' -%}

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {%- render 'head.social-meta-tags' -%}

    {%- style -%}
      :root {
        --product-grid-padding: 12px;
      }
    {%- endstyle -%}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');

      window.theme = window.theme || {};

      theme.settings = {
        themeName: 'Expanse',
        themeVersion: '9.1.0', // x-release-please-version
      };
    </script>

    {%- render 'head.import-map' -%}
    {%- render 'head.es-module-shims' -%}
    {%- render 'head.is-land' -%}
    {%- render 'head.preload-js' -%}
    {%- render 'head.theme-editor' -%}

    {{ content_for_header }}

    {%- render 'head.styles' -%}
    {%- render 'utility.stylesheet', name: 'overrides.css', load: 'inline' -%}

    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>

    {%- if request.page_type contains 'customers/' -%}
      <script src="{{ 'shopify_common.js' | shopify_asset_url }}" defer="defer"></script>
    {%- endif -%}

    {% if request.design_mode %}
      <script>
        theme.settings.email = {{ shop.email | json }}
      </script>
      <script src="https://api.archetypethemes.co/design-mode.js" defer="defer"></script>
    {% endif %}

