{% comment %}

snippet to add a "available in shop" label to products that are available in stock but not online

{% endcomment %}


<style>
    .available_in_stock_pill {
        position: absolute;
        top: 10px;
        left: 10px;
        padding: 4px 10px;
        display: inline-block;
        z-index: 10;
        background: #10b981;
        color: #ffffff;
        border-radius: 10px;
        text-transform: uppercase;
        font-size: 12px;
        font-weight: 600;
    }
</style>


{% if product.metafields.custom.in_stock_online == false and product.metafields.custom.in_stock_shop == true  %}
    
    <span class = "available_in_stock_pill" > 
        Available in Store
    </span>
    
{% endif %}