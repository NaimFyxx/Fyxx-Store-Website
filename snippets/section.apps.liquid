  Copyright © 2025 Archetype Themes LP. All rights reserved.

  App embed section for third-party Shopify app integrations.

  @param {boolean} [full_width] - Enable full-width layout
  @param {boolean} [space_around] - Add spacing around section

  @example
  {% render 'section.apps', full_width: true %}
{% enddoc %}

{%- liquid
  assign full_width = full_width | default: section.settings.full_width, allow_false: true | default: false, allow_false: true
  assign space_around = space_around | default: section.settings.space_around, allow_false: true | default: true, allow_false: true
-%}

{%- if space_around -%}
  <div class="index-section">
{%- endif -%}

{%- unless full_width -%}
  <div class="page-width">
{%- endunless -%}

{%- for block in section.blocks -%}
  {% render block %}
{%- endfor -%}

{%- unless full_width -%}
  </div>
{%- endunless -%}

{%- if space_around -%}
  </div>
{%- endif -%}
