{% doc %}
  Copyright © 2025 Archetype Themes LP. All rights reserved.

  Product recommendations displayed in the cart to encourage additional purchases.

  @param {string} [context] - Rendering context ('drawer', 'popup', etc.)
  @param {collection} [collection] - Collection to source recommendations from

  @example
  {% render 'cart.recommendations', context: 'drawer', collection: settings.cart_collection %}
{% enddoc %}

{% stylesheet %}
  /*Recommended products*/
  .cart__recommended-title {
    margin-bottom: 20px;
  }
{% endstylesheet %}

{%- liquid
  assign context = context | default: blank
  assign collection = collection | default: settings.cart_collection
  assign product_grid_content_align = product_grid_content_align | default: settings.product_grid_content_align | default: 'start'
  assign mobile_scroll_only = true

  if context == 'drawer'
    assign mobile_scroll_only = false
  endif
-%}

{%- if collection != blank -%}
  <div class="cart__item-row cart-recommendations" data-location="{{ context }}">
    <div class="heading-md cart__recommended-title">
      {% render 'utility.translate', key: 'labels.goes_great_with', fallback: 'Goes great with' %}
    </div>
    <div
      class="new-grid product-grid{% if mobile_scroll_only %} scrollable-grid--small{% else %} scrollable-grid{% endif %}"
      data-view="small"
    >
      {%- liquid
        for product in collection.products limit: 4
          render 'list.product-card', product: product, collection: collection, sizes: '150px', product_grid_content_align: product_grid_content_align
        endfor
      -%}
    </div>
  </div>
{%- endif -%}
