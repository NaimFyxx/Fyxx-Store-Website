  Close button for cart dropdown drawer (only renders for dropdown cart type).

  @param {string} [close_cart_button] - Custom close button HTML
  @param {string} [cart_type] - Cart display type, defaults to theme setting

  @example
  {% render 'header.close-cart', cart_type: 'dropdown' %}
{% enddoc %}

{%- liquid
  assign cart_type = cart_type | default: settings.cart_type | default: 'page'
-%}

{%- if cart_type == 'dropdown' -%}
  <close-cart>
    {{- close_cart_button -}}
  </close-cart>
  <script type="module">
    import 'header.close-cart'
  </script>
{%- endif -%}
