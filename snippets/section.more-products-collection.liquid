  Additional products grid from a specific collection.

  @param {object} [collection] - Collection to display from
  @param {number} [max_products] - Maximum products to show
  @param {string} [product_grid_content_align] - Product grid content alignment ('start'|'center'|'end')

  @example
  {% render 'section.more-products-collection', max_products: 8 %}
{% enddoc %}

{%- liquid
  assign collection = section.settings.collection | default: collection
  assign max_products = max_products | default: section.settings.max_products | default: 5
  assign product_grid_content_align = product_grid_content_align | default: settings.product_grid_content_align | default: 'start'
-%}

{%- if collection and collection.handle != blank -%}
  {%- capture collection_link -%}
    <a href="{{ collection.url }}">{{ collection.title }}</a>
  {%- endcapture -%}

  <div
    data-subsection
    data-section-id="{{ section.id }}"
    data-section-type="collection-template"
  >
    <div class="index-section index-section--sub-product">
      <div class="page-width">
        <header class="section-header">
          <div class="heading-md section-header__title">
            {% assign labels_more_from_html = 'labels.more_from_html' | t: link: collection_link %}
            {%- capture fallback_labels_more_from_html -%}
              More from {{ collection_link }}
            {%- endcapture -%}
            {% render 'utility.translate', t: labels_more_from_html, fallback: fallback_labels_more_from_html %}
          </div>
        </header>
      </div>

      <div class="page-width page-width--flush-small">
        <div
          class="new-grid product-grid scrollable-grid--small"
          {% render 'utility.grid-view-type', products_per_row: products_per_row %}
        >
          {%- liquid
            for product in collection.products limit: max_products
              render 'list.product-card', product: product, collection: collection, sizeVariable: products_per_row, fallback: '45vw', product_grid_content_align: product_grid_content_align
            endfor
          -%}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}
