{% doc %}
  Copyright © 2025 Archetype Themes LP. All rights reserved.

  Rich text content section with optional narrow column and decorative backgrounds.

  @param {boolean} [divider] - Show divider above section
  @param {string} [color_scheme] - ('none'|'1'|'2'|'3') Color scheme
  @param {string} [align_text] - ('left'|'center'|'right') Text alignment
  @param {boolean} [narrow_column] - Use narrow content width
  @param {boolean} [show_wave] - Display wave background decoration

  @example
  {% render 'section.rich-text', narrow_column: true, align_text: 'center' %}
{% enddoc %}

{% stylesheet %}
  .rich-text-section .background-svg--wave {
    & .page-width {
      @media only screen and (min-width: 769px) {
        padding-bottom: 20px;
      }
    }
  }
{% endstylesheet %}

{%- liquid
  assign divider = divider | default: section.settings.divider, allow_false: true | default: false, allow_false: true
  assign color_scheme = color_scheme | default: section.settings.color_scheme | default: 'none'
  assign align_text = align_text | default: section.settings.align_text | default: 'left'
  assign narrow_column = narrow_column | default: section.settings.narrow_column, allow_false: true | default: false, allow_false: true
  assign show_wave = show_wave | default: section.settings.show_wave, allow_false: true | default: false, allow_false: true
-%}

{%- if divider -%}<div class="section--divider">{%- endif -%}

<div class="index-section color-scheme-{{ color_scheme }} text-{{ align_text }} {% if show_wave %}background-svg--wave{% endif %}">
  {%- render 'utility.color-scheme-texture', color_scheme: color_scheme -%}

  <div class="page-width{% if narrow_column %} page-width--narrow{% endif %}" style="z-index: 1;">
    {%- for block in section.blocks -%}
      <div class="theme-block" {{ block.shopify_attributes }}>
        {%- case block.type -%}
          {%- when 'heading' -%}
            {% if block.settings.text_highlight %}
              <h2
                class="
                  heading-{{ block.settings.heading_size }}
                  text-highlight
                  text-highlight--{{ block.settings.text_highlight }}
                "
              >
                {{ block.settings.title }}
              </h2>
            {% else %}
              <h2 class="heading-{{ block.settings.heading_size }}">{{ block.settings.title }}</h2>
            {% endif %}
          {%- when 'page' -%}
            {%- liquid
              assign slot = 'info.section_no_content' | t
              if block.settings.page_text != blank
                assign slot = pages[block.settings.page_text].content
              endif

              render 'element.text', text: slot, variant: 'rte'
            -%}
          {%- when 'text' -%}
            <div class="rte clearfix">
              {%- if block.settings.text != blank -%}
                {%- if block.settings.enlarge_text %}<div class="enlarge-text">{% endif -%}
                {{ block.settings.text }}
                {%- if block.settings.enlarge_text %}
                  </div>
                {% endif -%}
              {%- else -%}
                {% render 'utility.translate',
                  key: 'info.section_no_content',
                  fallback: "This section doesn't currently include any content. Add content to this section using the sidebar."
                %}
              {%- endif -%}
            </div>
          {%- when 'button' -%}
            <div class="rte clearfix">
              {%- render 'element.button', text: block.settings.link_text, href: block.settings.link -%}
            </div>
        {%- endcase -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{%- if divider -%}</div>{%- endif -%}
