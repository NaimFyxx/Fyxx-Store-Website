{% comment %} ===== FYXX CUSTOM: Birthday landing for the Klaviyo birthday flow (/pages/birthday-gift-unlocked). Keep. ===== {% endcomment %}
{% comment %} Prevent indexing {% endcomment %}
<meta name="robots" content="noindex, nofollow">

<section class="fyxx-bday-wrap">
  <!-- Confetti -->
  <div class="fyxx-confetti" aria-hidden="true">
    {% for i in (1..30) %}
      <span class="fyxx-confetti-piece"></span>
    {% endfor %}
  </div>

  <div class="fyxx-content">
    <!-- Logo / Image -->
    <a class="fyxx-logo" href="https://www.myfyxx.com" target="_blank" rel="noopener noreferrer">
     <img
  src="https://cdn.shopify.com/s/files/1/0108/6328/0224/files/fyxx-balloons.png?v=1768311430"
  alt="FYXX Balloons"
  width="960"
  height="540"

  loading="lazy"
>

    </a>

    <h1>Something Special<br>is Coming...</h1>

    <p class="fyxx-subtext">
      Your surprise is almost ready.
    </p>

    <p class="fyxx-subtext fyxx-mail">
      ✉️ <span>Check your inbox very soon!</span>
    </p>

    <div class="fyxx-dots" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>

    <a class="fyxx-btn" href="https://www.myfyxx.com" target="_blank" rel="noopener noreferrer">
      Explore FYXX
    </a>
  </div>

  <footer class="fyxx-footer">
    With love, from FYXX
  </footer>
</section>

<style>
  .fyxx-bday-wrap{
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    text-align: center;
    background: #ffffff;
    overflow: hidden;
    font-family: Georgia, 'Times New Roman', serif;
  }

  .fyxx-content{
    max-width: 560px;
    z-index: 2;
  }

  .fyxx-logo img{
    width: 320px;
    max-width: 100%;
    height: auto;
    display: block;
    margin: 0 auto 28px auto;
  }

  .fyxx-content h1{
    margin: 0 0 18px 0;
    font-size: 44px;
    line-height: 1.1;
    font-weight: 700;
    color: #000;
  }

  @media (max-width: 600px){
    .fyxx-content h1{
      font-size: 34px;
    }
  }

  .fyxx-subtext{
    margin: 0;
    font-size: 18px;
    line-height: 1.6;
    color: rgba(0,0,0,0.70);
  }

  .fyxx-mail{
    margin-top: 10px;
    display: inline-flex;
    gap: 10px;
    align-items: center;
    justify-content: center;
  }

  .fyxx-dots{
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 18px;
    margin-bottom: 26px;
  }

  .fyxx-dots span{
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #F4E3DA;
    animation: fyxxDotPulse 1.2s ease-in-out infinite;
    opacity: 0.6;
  }

  .fyxx-dots span:nth-child(2){ animation-delay: .2s; }
  .fyxx-dots span:nth-child(3){ animation-delay: .4s; }

  @keyframes fyxxDotPulse{
    0%, 100%{ transform: scale(1); opacity: .6; }
    50%{ transform: scale(1.6); opacity: 1; }
  }

  .fyxx-btn{
    display: inline-block;
    padding: 14px 26px;
    border-radius: 999px;
    background: #000;
    color: #fff;
    text-decoration: none;
    font-size: 13px;
    letter-spacing: .6px;
    text-transform: uppercase;
    transition: transform .15s ease;
  }

  .fyxx-btn:hover{ transform: scale(1.03); }

  .fyxx-footer{
    position: absolute;
    left: 0;
    right: 0;
    bottom: 22px;
    font-size: 13px;
    color: rgba(0,0,0,0.50);
    z-index: 2;
  }

  /* Confetti */
  .fyxx-confetti{
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 1;
  }

  .fyxx-confetti-piece{
    position: absolute;
    top: -20px;
    width: 10px;
    height: 10px;
    background: #F4E3DA;
    opacity: 0.9;
    border-radius: 2px;
    animation: fyxxFall 6s linear infinite;
  }

  /* Random-ish positions using nth-child */
  .fyxx-confetti-piece:nth-child(1){ left: 5%; animation-delay: 0s; }
  .fyxx-confetti-piece:nth-child(2){ left: 12%; animation-delay: .7s; border-radius: 999px; }
  .fyxx-confetti-piece:nth-child(3){ left: 18%; animation-delay: 1.3s; transform: rotate(45deg); }
  .fyxx-confetti-piece:nth-child(4){ left: 25%; animation-delay: .2s; }
  .fyxx-confetti-piece:nth-child(5){ left: 32%; animation-delay: 1.7s; border-radius: 999px; }
  .fyxx-confetti-piece:nth-child(6){ left: 40%; animation-delay: .9s; transform: rotate(45deg); }
  .fyxx-confetti-piece:nth-child(7){ left: 48%; animation-delay: 1.1s; }
  .fyxx-confetti-piece:nth-child(8){ left: 56%; animation-delay: .4s; border-radius: 999px; }
  .fyxx-confetti-piece:nth-child(9){ left: 63%; animation-delay: 1.9s; transform: rotate(45deg); }
  .fyxx-confetti-piece:nth-child(10){ left: 70%; animation-delay: .6s; }
  .fyxx-confetti-piece:nth-child(11){ left: 76%; animation-delay: 1.5s; border-radius: 999px; }
  .fyxx-confetti-piece:nth-child(12){ left: 82%; animation-delay: .1s; transform: rotate(45deg); }
  .fyxx-confetti-piece:nth-child(13){ left: 88%; animation-delay: 1.0s; }
  .fyxx-confetti-piece:nth-child(14){ left: 93%; animation-delay: 1.8s; border-radius: 999px; }
  .fyxx-confetti-piece:nth-child(15){ left: 97%; animation-delay: .3s; transform: rotate(45deg); }

  .fyxx-confetti-piece:nth-child(n+16){
    animation-duration: 7.5s;
    opacity: .75;
  }

  @keyframes fyxxFall{
    0%   { transform: translateY(-20px) rotate(0deg); }
    100% { transform: translateY(110vh) rotate(360deg); }
  }
</style>
<script>
document.addEventListener("DOMContentLoaded", function () {
  // Get gift from URL: ?gift=burger / cocktail / wine / 15
  const params = new URLSearchParams(window.location.search);
  const gift = params.get("gift");

  // Only run if one of the 4 gift values exists
  const allowedGifts = ["burger", "cocktail", "wine", "15"];
  if (!gift || !allowedGifts.includes(gift)) return;

  // Klaviyo tracking array
  window._learnq = window._learnq || [];

  // Fire event to Klaviyo (this creates the "gift" property inside the event)
  window._learnq.push([
    "track",
    "Birthday Gift Selected",
    {
      gift: gift,
      page: window.location.pathname,
      full_url: window.location.href
    }
  ]);
});
</script>
