{% comment %}
  ===== FYXX CUSTOM: slide-in cart drawer =====
  Ported from the approved prototype (fyxx-cart-drawer-prototype.html).
  Right-side drawer that matches the new header's design system.

  - Renders the REAL {{ cart }} via Liquid (correct money formatting incl. JOD).
  - Opens ONLY when the header cart icon is clicked (listens for the 'fyxx-cart:open'
    event). It NEVER auto-opens when something is added to the cart.
  - Quantity / remove run through Shopify's AJAX cart (/cart/change.js) and the drawer
    re-renders itself via the Section Rendering API so totals stay theme-accurate.
  - Checkout + dynamic payment buttons come from {% raw %}{% form 'cart' %}{% endraw %}.

  This REPLACES the theme's slide-down cart (header.drawer / header.cart-drawer), which
  fyxx-header.liquid no longer renders.
{% endcomment %}

{% stylesheet %}
  fyxx-cart-drawer {
    --cd-bg:        #ffffff;
    --cd-fg:        #231F20;
    --cd-muted:     rgba(0,0,0,.55);
    --cd-faint:     rgba(0,0,0,.40);
    --cd-hairline:  rgba(0,0,0,.12);
    --cd-soft:      rgba(0,0,0,.04);
    --cd-accent:    #f0b09e;
    --cd-accent-deep:#e39c86;
    --cd-btn-bg:    #231F20;
    --cd-btn-fg:    #ffffff;
    --cd-radius:    12px;
    --cd-ui-font:   var(--element-text-font-family--body), var(--element-text-font-family-fallback--body);
    --cd-serif:     var(--element-text-font-family--heading), var(--element-text-font-family-fallback--heading);
    display: block;
  }
  fyxx-cart-drawer *, fyxx-cart-drawer *::before, fyxx-cart-drawer *::after { box-sizing: border-box; }

  .fyxx-cd-icon { width: 22px; height: 22px; stroke: var(--cd-fg); fill: none; stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }

  /* scrim */
  .fyxx-cd-scrim {
    position: fixed; inset: 0; background: rgba(0,0,0,.45);
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity .25s ease; z-index: 10040;
  }
  fyxx-cart-drawer.is-open .fyxx-cd-scrim { opacity: 1; visibility: visible; pointer-events: auto; }

  /* drawer */
  .fyxx-cd {
    position: fixed; top: 0; right: 0; bottom: 0; width: 410px; max-width: 92vw;
    background: var(--cd-bg); color: var(--cd-fg);
    transform: translateX(100%); transition: transform .3s cubic-bezier(.18,.77,.58,1);
    z-index: 10050; display: flex; flex-direction: column;
    box-shadow: -8px 0 40px rgba(0,0,0,.16);
    font-family: var(--cd-ui-font);
  }
  fyxx-cart-drawer.is-open .fyxx-cd { transform: translateX(0); }
  @media (max-width: 768px) { .fyxx-cd { width: 100%; max-width: none; } }

  /* header */
  .fyxx-cd__header { display: flex; align-items: center; justify-content: space-between; padding: 20px 22px; border-bottom: 1px solid var(--cd-hairline); }
  .fyxx-cd__title { display: flex; align-items: baseline; gap: 10px; }
  .fyxx-cd__title h2 { font-family: var(--cd-serif); font-weight: 700; font-size: 19px; margin: 0; letter-spacing: .01em; }
  .fyxx-cd__count { font-size: 13px; color: var(--cd-muted); }
  .fyxx-cd-iconbtn { width: 38px; height: 38px; border-radius: 10px; border: 0; background: none; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; transition: background .15s ease; }
  .fyxx-cd-iconbtn:hover { background: var(--cd-soft); }

  /* items */
  .fyxx-cd__items { flex: 1 1 auto; overflow-y: auto; overscroll-behavior: contain; -webkit-overflow-scrolling: touch; padding: 6px 22px; }
  .fyxx-cd-item { display: flex; gap: 14px; padding: 18px 0; border-bottom: 1px solid var(--cd-hairline); }
  .fyxx-cd-item__media { flex: 0 0 auto; width: 68px; height: 68px; border-radius: 8px; background: #ffffff; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .fyxx-cd-item__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .fyxx-cd-item__media .fyxx-cd-icon { stroke: var(--cd-faint); width: 26px; height: 26px; }
  .fyxx-cd-item__info { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; }
  .fyxx-cd-item__row { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
  .fyxx-cd-item__title { font-size: 14.5px; font-weight: 600; color: var(--cd-fg); text-decoration: none; }
  .fyxx-cd-item__title:hover { color: var(--cd-accent-deep); }
  .fyxx-cd-item__variant { font-size: 12.5px; color: var(--cd-muted); margin-top: 3px; }
  .fyxx-cd-item__remove { flex: 0 0 auto; width: 30px; height: 30px; border: 0; background: none; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; color: var(--cd-muted); transition: color .15s ease, background .15s ease; }
  .fyxx-cd-item__remove .fyxx-cd-icon { width: 17px; height: 17px; stroke: currentColor; }
  .fyxx-cd-item__remove:hover { color: var(--cd-accent-deep); background: var(--cd-soft); }
  .fyxx-cd-item__bottom { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 12px; }
  .fyxx-cd-item__price { font-size: 14px; font-weight: 600; }

  /* qty stepper */
  .fyxx-cd-qty { display: inline-flex; align-items: center; border: 1px solid var(--cd-hairline); border-radius: 10px; overflow: hidden; }
  .fyxx-cd-qty button { width: 32px; height: 34px; border: 0; background: none; cursor: pointer; font-size: 17px; line-height: 1; color: var(--cd-fg); display: inline-flex; align-items: center; justify-content: center; transition: background .15s ease, color .15s ease; }
  .fyxx-cd-qty button:hover { background: var(--cd-accent); color: var(--cd-fg); }
  .fyxx-cd-qty button:disabled { opacity: .4; cursor: default; background: none; }
  .fyxx-cd-qty span { min-width: 30px; text-align: center; font-size: 14px; font-weight: 600; }

  /* footer */
  .fyxx-cd__footer { border-top: 1px solid var(--cd-hairline); padding: 18px 22px 22px; background: var(--cd-bg); }
  .fyxx-cd__footer-form { margin: 0; }
  .fyxx-cd-subtotal { display: flex; align-items: baseline; justify-content: space-between; }
  .fyxx-cd-subtotal .fyxx-cd-label { font-size: 14px; font-weight: 600; }
  .fyxx-cd-subtotal .fyxx-cd-amount { font-size: 18px; font-weight: 700; }
  .fyxx-cd-note { font-size: 12px; color: var(--cd-muted); margin: 6px 0 16px; }
  .fyxx-cd-checkout { display: block; width: 100%; text-align: center; cursor: pointer; background: var(--cd-btn-bg); color: var(--cd-btn-fg); border: 0; border-radius: var(--cd-radius); padding: 15px 20px; font-family: var(--cd-ui-font); font-weight: 700; font-size: 13px; letter-spacing: .06em; text-transform: uppercase; text-decoration: none; transition: background .15s ease, color .15s ease; }
  .fyxx-cd-checkout:hover { background: var(--cd-accent); color: var(--cd-fg); }
  .fyxx-cd-dynamic { margin-top: 10px; }
  .fyxx-cd-dynamic:empty { display: none; }
  .fyxx-cd-viewcart { display: block; text-align: center; margin-top: 12px; font-size: 13px; color: var(--cd-muted); text-decoration: none; }
  .fyxx-cd-viewcart:hover { color: var(--cd-accent-deep); text-decoration: underline; }

  /* empty state */
  .fyxx-cd__empty { flex: 1 1 auto; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 40px 30px; gap: 6px; }
  .fyxx-cd__empty .fyxx-cd-empty-icon { width: 56px; height: 56px; stroke: var(--cd-faint); fill: none; stroke-width: 1.5; margin-bottom: 8px; }
  .fyxx-cd__empty h2 { font-family: var(--cd-serif); font-weight: 700; font-size: 20px; margin: 0; }
  .fyxx-cd__empty p { font-size: 14px; color: var(--cd-muted); margin: 0 0 18px; max-width: 250px; line-height: 1.5; }
  .fyxx-cd-continue { background: var(--cd-btn-bg); color: var(--cd-btn-fg); border: 0; cursor: pointer; border-radius: var(--cd-radius); padding: 14px 28px; font-weight: 700; font-size: 13px; letter-spacing: .06em; text-transform: uppercase; transition: background .15s ease, color .15s ease; }
  .fyxx-cd-continue:hover { background: var(--cd-accent); color: var(--cd-fg); }

  fyxx-cart-drawer.is-loading .fyxx-cd { cursor: progress; }
  fyxx-cart-drawer.is-loading .fyxx-cd__items { opacity: .55; pointer-events: none; transition: opacity .15s ease; }

  fyxx-cart-drawer a:focus-visible, fyxx-cart-drawer button:focus-visible { outline: 2px solid var(--cd-accent); outline-offset: 2px; border-radius: 6px; }
  @media (prefers-reduced-motion: reduce) { fyxx-cart-drawer * { transition: none !important; } }
{% endstylesheet %}

{%- liquid
  assign item_count = cart.item_count
  assign count_label = 'items'
  if item_count == 1
    assign count_label = 'item'
  endif
-%}

<fyxx-cart-drawer data-section-id="{{ section.id }}" data-item-count="{{ item_count }}">
  <div class="fyxx-cd-scrim" data-cd-close></div>

  <aside class="fyxx-cd" role="dialog" aria-modal="true" aria-label="Cart" aria-hidden="true">
    <div class="fyxx-cd__header">
      <div class="fyxx-cd__title">
        <h2>Your Cart</h2>
        <span class="fyxx-cd__count" data-cd-count>
          {%- if item_count > 0 -%}{{ item_count }} {{ count_label }}{%- endif -%}
        </span>
      </div>
      <button class="fyxx-cd-iconbtn" type="button" aria-label="Close cart" data-cd-close>
        <svg class="fyxx-cd-icon" viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>

    {%- if cart.item_count > 0 -%}
      <div class="fyxx-cd__items" data-cd-items>
        {%- for item in cart.items -%}
          <div class="fyxx-cd-item" data-cd-line-item data-key="{{ item.key }}">
            <a href="{{ item.url }}" class="fyxx-cd-item__media" aria-hidden="true" tabindex="-1">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 140 }}" alt="{{ item.product.title | escape }}" width="68" height="68" loading="lazy">
              {%- else -%}
                <svg class="fyxx-cd-icon" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="9.5" r="1.5"/><path d="M5 18l5-5 4 4 2-2 3 3"/></svg>
              {%- endif -%}
            </a>
            <div class="fyxx-cd-item__info">
              <div class="fyxx-cd-item__row">
                <div>
                  <a href="{{ item.url }}" class="fyxx-cd-item__title">{{ item.product.title }}</a>
                  {%- unless item.variant.title contains 'Default' -%}
                    <div class="fyxx-cd-item__variant">{{ item.variant.title }}</div>
                  {%- endunless -%}
                  {%- if item.selling_plan_allocation -%}
                    <div class="fyxx-cd-item__variant">{{ item.selling_plan_allocation.selling_plan.name }}</div>
                  {%- endif -%}
                  {%- for prop in item.properties -%}
                    {%- assign prop_key = prop.first | slice: 0 -%}
                    {%- if prop.last != blank and prop_key != '_' -%}
                      <div class="fyxx-cd-item__variant">{{ prop.first }}: {{ prop.last }}</div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                <button class="fyxx-cd-item__remove" type="button" data-cd-act="remove" data-key="{{ item.key }}" aria-label="Remove {{ item.product.title | escape }}">
                  <svg class="fyxx-cd-icon" viewBox="0 0 24 24"><path d="M4 7h16M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2M6 7l1 13a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1l1-13"/></svg>
                </button>
              </div>
              <div class="fyxx-cd-item__bottom">
                <div class="fyxx-cd-qty">
                  <button type="button" data-cd-act="dec" data-key="{{ item.key }}" aria-label="Decrease quantity">&#8722;</button>
                  <span data-cd-qty>{{ item.quantity }}</span>
                  <button type="button" data-cd-act="inc" data-key="{{ item.key }}" aria-label="Increase quantity">+</button>
                </div>
                <div class="fyxx-cd-item__price">
                  {%- if item.original_line_price > item.final_line_price -%}
                    {{ item.final_line_price | money }}
                  {%- else -%}
                    {{ item.final_line_price | money }}
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <div class="fyxx-cd__footer">
        {%- form 'cart', cart, class: 'fyxx-cd__footer-form' -%}
          <div class="fyxx-cd-subtotal">
            <span class="fyxx-cd-label">Subtotal</span>
            <span class="fyxx-cd-amount" data-cd-subtotal>{{ cart.total_price | money }}</span>
          </div>
          <p class="fyxx-cd-note">Shipping &amp; taxes calculated at checkout.</p>
          <button type="submit" name="checkout" class="fyxx-cd-checkout" data-cd-checkout>Checkout</button>
          {%- if additional_checkout_buttons -%}
            <div class="fyxx-cd-dynamic">{{ content_for_additional_checkout_buttons }}</div>
          {%- endif -%}
          <a href="{{ routes.cart_url }}" class="fyxx-cd-viewcart">View cart</a>
        {%- endform -%}
      </div>
    {%- else -%}
      <div class="fyxx-cd__empty" data-cd-empty>
        <svg class="fyxx-cd-empty-icon" viewBox="0 0 24 24"><path d="M6 6h15l-1.6 9.5a1 1 0 0 1-1 .8H8.6a1 1 0 0 1-1-.8L6 6z"/><path d="M6 6L5.2 3H2.5"/><circle cx="9.5" cy="20" r="1.4"/><circle cx="17.5" cy="20" r="1.4"/></svg>
        <h2>Your cart is empty</h2>
        <p>Nothing here yet. Browse the shop and your picks will land in the cart.</p>
        <button class="fyxx-cd-continue" type="button" data-cd-close>Continue shopping</button>
      </div>
    {%- endif -%}
  </aside>

  <script>
    (function () {
      var root = document.currentScript.closest('fyxx-cart-drawer');
      if (!root || root.dataset.cdInit) return;
      root.dataset.cdInit = '1';

      var sectionId = root.dataset.sectionId;
      var lastFocus = null;

      function open() {
        lastFocus = document.activeElement;
        root.classList.add('is-open');
        var panel = root.querySelector('.fyxx-cd');
        if (panel) panel.setAttribute('aria-hidden', 'false');
        document.documentElement.style.overflow = 'hidden';
        // refresh on open so anything added silently shows up
        refresh();
        var closeBtn = root.querySelector('[data-cd-close]');
        if (closeBtn && closeBtn.focus) { try { closeBtn.focus(); } catch (e) {} }
      }
      function close() {
        root.classList.remove('is-open');
        var panel = root.querySelector('.fyxx-cd');
        if (panel) panel.setAttribute('aria-hidden', 'true');
        document.documentElement.style.overflow = '';
        if (lastFocus && lastFocus.focus) { try { lastFocus.focus(); } catch (e) {} }
      }

      // The header cart icon asks us to open via this event (it never auto-opens on add).
      document.addEventListener('fyxx-cart:open', open);

      // delegated close + checkout
      root.addEventListener('click', function (e) {
        if (e.target.closest('[data-cd-close]')) { e.preventDefault(); close(); return; }
        // Checkout: navigate straight to /checkout so the theme's cart JS can't swallow the submit.
        var co = e.target.closest('[data-cd-checkout]');
        if (co) { e.preventDefault(); window.location.href = routeRoot + 'checkout'; return; }
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && root.classList.contains('is-open')) close();
      });

      // quantity + remove (delegated)
      root.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-cd-act]');
        if (!btn) return;
        e.preventDefault();
        var act = btn.dataset.act || btn.getAttribute('data-cd-act');
        var key = btn.getAttribute('data-key');
        if (!key) return;
        var row = btn.closest('[data-cd-line-item]');
        var qtyEl = row ? row.querySelector('[data-cd-qty]') : null;
        var current = qtyEl ? parseInt(qtyEl.textContent, 10) || 0 : 0;
        var next = current;
        if (act === 'inc') next = current + 1;
        else if (act === 'dec') next = Math.max(0, current - 1);
        else if (act === 'remove') next = 0;
        changeLine(key, next);
      });

      var routeRoot = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';

      // Swap in freshly-rendered section HTML (keeps Liquid money formatting).
      function applySectionHTML(html) {
        if (!html) return;
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var fresh = doc.querySelector('fyxx-cart-drawer .fyxx-cd');
        var current = root.querySelector('.fyxx-cd');
        if (fresh && current) current.innerHTML = fresh.innerHTML;
        var fc = doc.querySelector('fyxx-cart-drawer');
        if (fc && fc.dataset.itemCount != null) {
          root.dataset.itemCount = fc.dataset.itemCount;
          updateBadge(parseInt(fc.dataset.itemCount, 10) || 0);
        }
      }

      var busy = false;
      function changeLine(key, quantity) {
        if (busy) return;
        busy = true;
        root.classList.add('is-loading');
        fetch(routeRoot + 'cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: key, quantity: quantity, sections: sectionId, sections_url: window.location.pathname })
        })
          .then(function (r) { return r.json(); })
          .then(function (cart) {
            if (cart) {
              if (typeof cart.item_count === 'number') updateBadge(cart.item_count);
              if (cart.sections && cart.sections[sectionId]) applySectionHTML(cart.sections[sectionId]);
              else refresh();
            }
          })
          .catch(function () {})
          .then(function () { busy = false; root.classList.remove('is-loading'); });
      }

      // Re-render the drawer from the Section Rendering API.
      function refresh() {
        return fetch(routeRoot + '?sections=' + encodeURIComponent(sectionId), { headers: { 'Accept': 'application/json' } })
          .then(function (r) { return r.json(); })
          .then(function (data) { if (data && data[sectionId]) applySectionHTML(data[sectionId]); })
          .catch(function () {});
      }

      // Keep the header cart badge in sync (the drawer never opens itself here).
      function updateBadge(count) {
        document.querySelectorAll('.fyxx-cart-count').forEach(function (el) {
          el.textContent = count;
          el.style.display = count > 0 ? '' : 'none';
        });
      }

      // Detect cart mutations from ANYWHERE (add / change / update) so the badge + drawer
      // stay fresh — WITHOUT ever opening the drawer. This is what makes "add" silent.
      if (!window.__fyxxCartHook) {
        window.__fyxxCartHook = true;
        var nativeFetch = window.fetch;
        window.fetch = function () {
          var args = arguments;
          var url = '';
          try { url = (typeof args[0] === 'string') ? args[0] : (args[0] && args[0].url) || ''; } catch (e) {}
          var p = nativeFetch.apply(this, args);
          if (/\/cart\/(add|change|update|clear)(\.js)?(\?|$)/.test(url)) {
            p.then(function () {
              document.dispatchEvent(new CustomEvent('fyxx-cart:mutated'));
            }).catch(function () {});
          }
          return p;
        };
      }
      document.addEventListener('fyxx-cart:mutated', function () {
        if (busy) return; // our own qty/remove already handles its refresh
        // refresh quietly; only re-render DOM if the drawer is open, else just sync the badge
        fetch(routeRoot + 'cart.js', { headers: { 'Accept': 'application/json' } })
          .then(function (r) { return r.json(); })
          .then(function (cart) { updateBadge(cart.item_count); if (root.classList.contains('is-open')) refresh(); })
          .catch(function () {});
      });
    })();
  </script>
</fyxx-cart-drawer>

{% schema %}
{
  "name": "Fyxx cart drawer",
  "settings": [],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
