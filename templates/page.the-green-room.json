image":"shopify:\/\/shop_images\/TGR_HolidaySchedule_Templates-2-04.jpg","image_mask":"none","image_width":650,"title":"Latin Grooves feat. DJ Harris","text":"<p>This night will move your soul and your feet—get ready to keep the shebeen shaking.<\/p>","button_label":"Book a Table","button_link":"https:\/\/www.sevenrooms.com\/experiences\/thegreenroombyfyxx\/rare-latin-grooves-5767640811847680?tracking=website"}},"text_block_AreUrm":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/Mosaica_Post_TGR_HolidaySchedule_Templates-2.jpg","image_mask":"none","image_width":650,"title":"All You Can Drink Wine for 25 JOD + a Live Performance by Mosaica Singers","text":"<p>Enjoy all-you-can-drink wines at JOD 25 per person. At 9 PM, the evening transforms as a special choir takes the stage.<\/p>","button_label":"Get Tickets","button_link":"shopify:\/\/products\/all-you-can-drink-wine-choir-evening"}}},"block_order":["text_block_VbtKLP","text_block_hWbn9Q","text_block_AreUrm"],"disabled":true,"settings":{"title":"","align_text":"left","divider":false,"color_scheme":"none"}},"text_and_image_jGfkGU":{"type":"text-and-image","settings":{"image":"shopify:\/\/shop_images\/DSC06630_b8a826b2-6c03-433f-9ea8-62c3effb9969.jpg","image_mask":"portrait","image2":"shopify:\/\/shop_images\/Screenshot_2024-11-18_at_12.55.34_PM.png","image2_mask":"portrait","subtitle":"Familiar & Made to Share","title":"Our Food Menu","heading_size":"h2","text":"<p>Our menu draws inspiration from the tapas culture in Spain with a twist that brings it closer to home. We aim to highlight locally sourced ingredients that are seasonal and fresh. At the heart of our offering is a celebration of Middle Eastern flavors, reimagined in small, shareable plates that embody both tradition and creativity, all within the comfort of familiarity.<\/p>","button_label":"See Food Menu","button_link":"https:\/\/ugc.production.linktr.ee\/1899c4d2-1778-400c-a8d9-fd53dfc6932d_V2.-TGR-FoodMenu---Updated-December-15.pdf","button_style":"secondary","align_text":"left","image_width":"50","layout":"left","color_scheme":"none","divider":false,"top_padding":true,"bottom_padding":true}},"text_and_image_6aqmWH":{"type":"text-and-image","settings":{"image":"shopify:\/\/shop_images\/DSC09860_e5d9d5c8-1d9e-47be-94a7-ace4de9915c0.jpg","image_mask":"portrait","image2":"shopify:\/\/shop_images\/DSC05251_267e0c01-acad-4afd-9ef0-60b823ef7446.jpg","image2_mask":"portrait","subtitle":"Think Flavor-Forward","title":"Our Cocktails","heading_size":"h2","text":"<p>Our cocktails are simple and delicious; we’ve reworked classic recipes in a way that brings out the most flavor using the least amount of ingredients. We use the highest quality spirits, and house-made cordials, liqueurs and tinctures to create flavor-forward cocktails that are refreshing and delicious.<\/p>","button_label":"See Cocktail Menu","button_link":"https:\/\/ugc.production.linktr.ee\/62081d12-4097-4b65-afc7-bba752b2850e_TGR-CocktailMenu-IG-new-.pdf","button_style":"secondary","align_text":"left","image_width":"50","layout":"right","color_scheme":"none","divider":false,"top_padding":true,"bottom_padding":true}},"testimonials_PDWbqU":{"type":"testimonials","blocks":{"testimonial_tNF7zy":{"type":"testimonial","settings":{"icon":"5-stars","testimonial":"<p><strong>Amazing, welcoming and kind people - fantastic ambience and food and drinks. Recommended!<\/strong><\/p>","author":"Megan","author_info":"Amman, Jordan"}},"testimonial_jhHnWq":{"type":"testimonial","settings":{"icon":"5-stars","testimonial":"<p><strong>We had the loveliest time at Fyxx and The Green Room as we always do and have to say that Jad just made the experience that much better with his friendly professional approach :)<\/strong><\/p>","author":"Sondos","author_info":"Amman, Jordan"}},"testimonial_7icKEd":{"type":"testimonial","settings":{"icon":"5-stars","testimonial":"<p><strong>Amazing staff! Amazing vibe<\/strong><\/p>","author":"Haya","author_info":"Amman, Jordan"}},"testimonial_7BqPDk":{"type":"testimonial","settings":{"icon":"4-stars","testimonial":"<p><strong>The new attendant, Abdullah, is a true gem. Try to keep him at whatever cost!<\/strong><\/p>","author":"Refat","author_info":"Amman, Jordan"}}},"block_order":["testimonial_tNF7zy","testimonial_jhHnWq","testimonial_7icKEd","testimonial_7BqPDk"],"settings":{"title":"Don't take our word for it. See what our guests are saying...","align_text":"center","round_images":true,"color_scheme":"none"}},"text_columns_j7633U":{"type":"text-columns","blocks":{"text_block_UPaFBn":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/FYXX_TEMPLATES-25.jpg","image_mask":"none","image_width":340,"title":"","text":"","button_label":"Learn More & Book Now","button_link":"https:\/\/www.sevenrooms.com\/experiences\/thegreenroombyfyxx\/tapas-sangria-6645219625500672?tracking=website"}},"text_block_7AhYgY":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/FYXX_TEMPLATES-24.jpg","image_mask":"none","image_width":340,"title":"","text":"","button_label":"Learn More & Book Now","button_link":"https:\/\/www.sevenrooms.com\/experiences\/thegreenroombyfyxx\/by-the-glass-6615825972428800?tracking=website"}}},"block_order":["text_block_UPaFBn","text_block_7AhYgY"],"disabled":true,"settings":{"title":"Weekly Happenings","align_text":"center","divider":true,"color_scheme":"none"}},"background_image_text_DKKAzB":{"type":"background-image-text","settings":{"subtitle":"Who We Are","title":"The Green Room","text":"<p>The Green Room is a small, modern bar serving big flavors. It was created out of a desire to bring high quality cocktails and food to a simple bar setting. We focus on the three main ingredients to make a bar successful: music, food, and drinks.<\/p>","button_label":"","button_link":"","image":"shopify:\/\/shop_images\/DSC05202-2_741489d1-c30f-4049-8b06-bdae415183d1.jpg","layout":"right","height":550,"par